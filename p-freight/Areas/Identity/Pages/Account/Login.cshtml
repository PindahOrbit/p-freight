@page
@model LoginModel

@{
    ViewData["Title"] = "Sign In";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-8 col-md-5 col-lg-4">
            <div class="text-center mb-4">
                <h2 class="fw-bold">Welcome back</h2>
                <p class="text-muted">Sign in to LoadLink SADC</p>
            </div>
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small" role="alert"></div>
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label small fw-bold">Email</label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label small fw-bold">Password</label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="••••••" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label asp-for="Input.RememberMe" class="form-check-label small">Remember me</label>
                        </div>
                        <div class="d-grid">
                            <button id="login-submit" type="submit" class="btn btn-primary py-2">Sign In</button>
                        </div>
                    </form>
                    <hr />
                    <div class="text-center small">
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a>
                        <span class="text-muted mx-1">·</span>
                        <a asp-page="./ForgotPassword">Forgot password?</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
