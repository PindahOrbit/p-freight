@model p_freight.Models.Truck

@{
    ViewData["Title"] = "Truck Details";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="fw-bold mb-0">Vehicle Details</h2>
                        <span class="badge @(Model.IsVerified == true ? "bg-success" : "bg-warning")">
                            @(Model.IsVerified == true ? "Verified" : "Pending Verification")
                        </span>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6 text-center text-md-start">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Registration</div>
                            <div class="fs-4 fw-bold text-primary">@Model.RegistrationNumber</div>
                        </div>
                        <div class="col-md-6 text-center text-md-start">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Vehicle Type</div>
                            <div class="fs-4 fw-bold">@Model.TruckType</div>
                        </div>
                    </div>

                    <hr />

                    <div class="row g-4 mb-4 mt-1">
                        <div class="col-md-6">
                            <div class="bg-light rounded p-3 h-100">
                                <div class="text-muted small text-uppercase fw-bold mb-1">Capacity</div>
                                <div class="fw-bold fs-5">@Model.CapacityWeight Tons</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light rounded p-3 h-100">
                                <div class="text-muted small text-uppercase fw-bold mb-1">Owner</div>
                                <div class="fw-bold">@Model.Owner?.UserName</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4">Edit Details</a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to Fleet</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
