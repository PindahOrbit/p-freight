@model p_freight.Models.Truck

@{
    ViewData["Title"] = "Edit Truck";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h2 class="fw-bold mb-1">Edit Vehicle</h2>
                    <p class="text-muted mb-4">Update information for registration <strong>@Model.RegistrationNumber</strong></p>
                    
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedAt" />
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="RegistrationNumber" class="form-label">Registration Number</label>
                                <input asp-for="RegistrationNumber" class="form-control" />
                                <span asp-validation-for="RegistrationNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="TruckType" class="form-label">Truck Category</label>
                                <select asp-for="TruckType" class="form-select">
                                    <option value="1-ton Pickup">1-ton Pickup</option>
                                    <option value="3-ton Truck">3-ton Truck</option>
                                    <option value="10-ton Rigid">10-ton Rigid</option>
                                    <option value="30-ton Stake">30-ton Stake</option>
                                    <option value="18-Wheel Hauler">18-Wheel Hauler</option>
                                </select>
                                <span asp-validation-for="TruckType" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CapacityWeight" class="form-label">Max Capacity (Tons)</label>
                            <input asp-for="CapacityWeight" class="form-control" type="number" step="0.1" />
                            <span asp-validation-for="CapacityWeight" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary py-2">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
