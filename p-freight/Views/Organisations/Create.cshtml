@model p_freight.Models.Organisation

@{
    ViewData["Title"] = "Create Organisation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card card-body shadow-sm">
                <h2 class="fw-bold text-dark mb-3">Add New Organisation</h2>
                <p class="text-muted mb-4">Register a new logistics partner to the SADC network.</p>
                
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label text-muted small text-uppercase fw-bold">Company Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. SADC Logistics Ltd" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Country" class="form-label text-muted small text-uppercase fw-bold">Operating Country</label>
                        <select asp-for="Country" class="form-select">
                            <option value="Zimbabwe">Zimbabwe</option>
                            <option value="South Africa">South Africa</option>
                            <option value="Zambia">Zambia</option>
                            <option value="Botswana">Botswana</option>
                            <option value="Mozambique">Mozambique</option>
                        </select>
                        <span asp-validation-for="Country" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Register Organisation</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel and Return</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
