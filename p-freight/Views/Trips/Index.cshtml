@model IEnumerable<p_freight.Models.Trip>

@{
    ViewData["Title"] = "Active Trips";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-dark mb-1">Trip Logistics</h1>
            <p class="text-muted">Monitor active shipments and delivery status across SADC corridors.</p>
        </div>
    </div>

    <div class="card card-body shadow-sm">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Cargo</th>
                        <th>Route</th>
                        <th>Driver</th>
                        <th>Status</th>
                        <th>Price</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="text-dark fw-bold">
                                @item.Load?.CargoType
                            </td>
                            <td>
                                <div class="small">
                                    <span class="text-muted">From:</span> @item.Load?.PickupAddress <br/>
                                    <span class="text-muted">To:</span> @item.Load?.DropoffAddress
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-secondary me-2" style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem;">
                                        @(item.Driver?.UserName?.Substring(0, 1).ToUpper() ?? "D")
                                    </div>
                                    <span class="text-dark small">@item.Driver?.UserName</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge @(item.Status == "IN_TRANSIT" ? "bg-primary" : "bg-info")">@item.Status</span>
                            </td>
                            <td class="fw-bold text-primary">$@item.AgreedPrice</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Track Live</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
