@model p_freight.Models.Load

@{
    ViewData["Title"] = "Post a Load";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                <h2 class="fw-bold mb-1">Post a New Load</h2>
                <p class="text-muted mb-4">Provide shipment details to receive bids from verified SADC drivers.</p>
                
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CargoType" class="form-label small text-uppercase fw-bold">Cargo Category</label>
                            <input asp-for="CargoType" class="form-control" placeholder="e.g. Grain, Cement, Furniture" />
                            <span asp-validation-for="CargoType" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Weight" class="form-label small text-uppercase fw-bold">Total Weight (Tons)</label>
                            <input asp-for="Weight" class="form-control" type="number" step="0.1" />
                            <span asp-validation-for="Weight" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PickupAddress" class="form-label small text-uppercase fw-bold">Pickup Location</label>
                            <div class="input-group">
                                <input asp-for="PickupAddress" id="pickupAddress" class="form-control" placeholder="e.g. Harare, Zimbabwe" />
                                <button type="button" class="btn btn-outline-secondary" onclick="detectLocation('pickup')">
                                    <i class="bi bi-geo-alt"></i>
                                </button>
                            </div>
                            <input type="hidden" asp-for="PickupLat" id="pickupLat" />
                            <input type="hidden" asp-for="PickupLng" id="pickupLng" />
                            <small id="pickupCoords" class="text-muted"></small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DropoffAddress" class="form-label small text-uppercase fw-bold">Delivery Location</label>
                            <input asp-for="DropoffAddress" class="form-control" placeholder="e.g. Johannesburg, South Africa" />
                            <input type="hidden" asp-for="DropoffLat" id="dropoffLat" />
                            <input type="hidden" asp-for="DropoffLng" id="dropoffLng" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SpecialNotes" class="form-label small text-uppercase fw-bold">Shipment Notes / Requirements</label>
                        <textarea asp-for="SpecialNotes" class="form-control" rows="3" placeholder="Fragile, Refrigerated, Extra insurance requested..."></textarea>
                    </div>



                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary py-2">Post Load for Bidding</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function detectLocation(type) {
            if (!navigator.geolocation) {
                alert('Geolocation is not supported by your browser.');
                return;
            }
            navigator.geolocation.getCurrentPosition(function(pos) {
                var lat = pos.coords.latitude;
                var lng = pos.coords.longitude;
                if (type === 'pickup') {
                    document.getElementById('pickupLat').value = lat;
                    document.getElementById('pickupLng').value = lng;
                    document.getElementById('pickupCoords').innerText = 'Detected: ' + lat.toFixed(4) + ', ' + lng.toFixed(4);
                    if (!document.getElementById('pickupAddress').value) {
                        document.getElementById('pickupAddress').value = 'Current Location (' + lat.toFixed(2) + ', ' + lng.toFixed(2) + ')';
                    }
                }
            }, function() {
                alert('Unable to detect location. Please enter the address manually.');
            });
        }
    </script>
}
