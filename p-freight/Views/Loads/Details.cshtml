@model p_freight.Models.Load

@{
    ViewData["Title"] = "Load Details";
}

<div class="container py-4">
    <div class="row g-4">
        <!-- Load Information -->
        <div class="col-lg-7">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="fw-bold mb-4">@Model.CargoType Delivery</h2>
                    
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Pickup</div>
                            <div class="fs-5">@Model.PickupAddress</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Destination</div>
                            <div class="fs-5">@Model.DropoffAddress</div>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="bg-light rounded p-3 text-center">
                                <div class="text-muted small text-uppercase">Weight</div>
                                <div class="fw-bold">@Model.Weight t</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="bg-light rounded p-3 text-center">
                                <div class="text-muted small text-uppercase">Status</div>
                                <div class="fw-bold">@Model.Status</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="bg-light rounded p-3 text-center">
                                <div class="text-muted small text-uppercase">Posted by</div>
                                <div class="fw-bold small">@Model.Customer?.UserName</div>
                            </div>
                        </div>

                    </div>

                    @if (!string.IsNullOrEmpty(Model.SpecialNotes)) {
                        <hr />
                        <div class="text-muted small text-uppercase fw-bold mb-1">Special Instructions</div>
                        <p>@Model.SpecialNotes</p>
                    }
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="fw-bold mb-3">Bids (@Model.LoadBids.Count)</h3>
                    @foreach(var bid in Model.LoadBids.OrderBy(b => b.OfferAmount)) {
                        <div class="bg-light rounded p-3 mb-3">
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                                <div>
                                    <div class="fw-bold">@bid.Driver?.UserName</div>
                                    <div class="text-muted small">@bid.Truck?.TruckType — @bid.Truck?.RegistrationNumber</div>
                                </div>
                                <div class="text-md-end">
                                    <div class="text-primary fw-bold fs-4">$@bid.OfferAmount</div>
                                    <div class="text-muted small">@bid.CreatedAt?.ToString("dd MMM, HH:mm")</div>
                                    @if(Model.Status == "PENDING" && Model.CustomerId == ViewData["CurrentUserId"]?.ToString()) {
                                        <form asp-controller="Trips" asp-action="AcceptBid" method="post" class="mt-2">
                                            <input type="hidden" name="bidId" value="@bid.Id" />
                                            <button type="submit" class="btn btn-sm btn-success">Accept Bid</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    @if(!Model.LoadBids.Any()) {
                        <div class="text-center py-4 text-muted">
                            No bids received yet. Be the first!
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Bidding Interface -->
        @if(Model.Status == "PENDING") {
            <div class="col-lg-5">
                <div class="card shadow-sm sticky-top" style="top: 80px;">
                    <div class="card-body">
                        <h3 class="fw-bold mb-1">Place a Bid</h3>
                        <p class="text-muted small mb-4">Propose your delivery price. The customer will review all offers.</p>
                        
                        <form asp-action="PlaceBid" method="post">
                            <input type="hidden" name="loadId" value="@Model.Id" />
                            
                            <div class="mb-3">
                                <label class="form-label small text-uppercase fw-bold">Select Your Truck</label>
                                <select name="truckId" class="form-select" required>
                                    <option value="">-- Choose a truck --</option>
                                    @if(ViewData["MyTrucks"] is Microsoft.AspNetCore.Mvc.Rendering.SelectList truckList) {
                                        @foreach(var item in truckList) {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                                <div class="form-text">Don't have a truck? <a asp-controller="Trucks" asp-action="Create">Register one first</a>.</div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small text-uppercase fw-bold">Your Offer (USD)</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" name="offerAmount" class="form-control fs-5 fw-bold" step="0.01" min="1" required />
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2">Submit Offer</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
